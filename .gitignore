# ChromaDB (embeddings - can be regenerated from verses.db, exclude to keep repo size down)
data/chromadb/

# Note: data/verses.db is INCLUDED in git because it contains:
# - All Bible verses (31k+ verses from KJV)
# - Enriched text from LLM (expensive to regenerate: ~1-2 hours with Qwen 2.5)
# This allows users to clone and use immediately without running populate script

